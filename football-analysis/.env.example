DATABASE_URL="file:./dev.db"

# Free-tier API keys — see README.md for how to obtain each one.
# Leave USE_MOCK_DATA=true to run entirely on bundled sample data with no keys.
USE_MOCK_DATA="true"
# The Odds API — real 1X2 + Asian Handicap + Over/Under odds (the-odds-api.com, free tier)
ODDS_API_KEY=""
# football-data.org — current-season goals for/against, strengthens the model (optional; free).
# If unset the model runs market-only. Register: https://www.football-data.org/client/register
FOOTBALLDATA_KEY=""

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Shared secret required in the `x-cron-secret` header to call /api/ingest/* and /api/analyze/* routes
CRON_SECRET="change-me"
