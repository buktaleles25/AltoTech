// Postgres variant of schema.prisma, used ONLY for the Vercel deployment target (serverless
// functions have no persistent filesystem, so the local-dev SQLite file won't work there).
// Keep this in sync with schema.prisma by hand — the only intended difference is the
// datasource `provider` line. Local dev keeps using schema.prisma + SQLite (see README).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id            String   @id @default(cuid())
  name          String
  shortName     String?
  league        String
  country       String?
  logoUrl       String?
  apiFootballId String?  @unique
  sportsDbId    String?  @unique
  // Current-season strength from football-data.org (null ⇒ market-only model for this team).
  gfPerGame         Float?
  gaPerGame         Float?
  strengthUpdatedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  homeFixtures Fixture[]  @relation("HomeTeam")
  awayFixtures Fixture[]  @relation("AwayTeam")
  lineups      Lineup[]
  newsItems    NewsItem[]

  @@index([league])
}

// status: SCHEDULED | LIVE | FINISHED | POSTPONED | CANCELLED (see lib/constants.ts)
model Fixture {
  id            String   @id @default(cuid())
  homeTeamId    String
  awayTeamId    String
  league        String
  kickoffAt     DateTime
  status        String   @default("SCHEDULED")
  homeScore     Int?
  awayScore     Int?
  apiFootballId String?  @unique
  oddsApiId     String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  homeTeam         Team              @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam         Team              @relation("AwayTeam", fields: [awayTeamId], references: [id])
  oddsSnapshots    OddsSnapshot[]
  marketQuotes     MarketQuote[]
  lineups          Lineup[]
  modelPredictions ModelPrediction[]
  picks            Pick[]

  @@index([kickoffAt])
  @@index([league])
}

model OddsSnapshot {
  id              String   @id @default(cuid())
  fixtureId       String
  bookmaker       String
  market          String   @default("h2h")
  homeOdds        Float
  drawOdds        Float?
  awayOdds        Float
  impliedHomeProb Float
  impliedDrawProb Float?
  impliedAwayProb Float
  isOpeningLine   Boolean  @default(false)
  capturedAt      DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@index([fixtureId, capturedAt])
}

// Two-way market snapshot (Asian Handicap or Over/Under). h2h stays in OddsSnapshot above.
// market: SPREAD | TOTAL. line = home handicap (SPREAD) or total goals line (TOTAL).
model MarketQuote {
  id              String   @id @default(cuid())
  fixtureId       String
  bookmaker       String
  market          String
  line            Float
  homeOrOverOdds  Float
  awayOrUnderOdds Float
  isOpeningLine   Boolean  @default(false)
  capturedAt      DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@index([fixtureId, market, capturedAt])
}

model Lineup {
  id                 String   @id @default(cuid())
  fixtureId          String
  teamId             String
  formation          String?
  isConfirmed        Boolean  @default(false)
  startingXiJson     String?
  missingPlayersJson String?
  capturedAt         DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id])

  @@unique([fixtureId, teamId])
}

model NewsItem {
  id            String   @id @default(cuid())
  title         String
  url           String   @unique
  source        String
  publishedAt   DateTime
  relatedTeamId String?
  summary       String?
  createdAt     DateTime @default(now())

  relatedTeam Team? @relation(fields: [relatedTeamId], references: [id])

  @@index([publishedAt])
  @@index([relatedTeamId])
}

model ModelPrediction {
  id                String   @id @default(cuid())
  fixtureId         String
  modelHomeProb     Float
  modelDrawProb     Float
  modelAwayProb     Float
  edgeHome          Float
  edgeDraw          Float
  edgeAway          Float
  expectedGoalsHome Float?
  expectedGoalsAway Float?
  confidenceScore   Float
  reasoning         String?
  computedAt        DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@index([fixtureId, computedAt])
}

// One recommended single value bet (not a parlay leg).
// market: H2H | AH | OU ; side: HOME|DRAW|AWAY|OVER|UNDER (see lib/constants.ts)
// result: PENDING | WON | HALF_WON | PUSH | HALF_LOST | LOST | VOID
model Pick {
  id              String    @id @default(cuid())
  fixtureId       String
  date            DateTime
  market          String
  side            String
  line            Float?
  odds            Float
  bookmaker       String
  modelProb       Float
  fairProb        Float
  edge            Float
  confidence      Float
  reasoning       String?
  result          String    @default("PENDING")
  profitLossUnits Float?
  // Closing-line value: the market's final pre-kickoff price for this same bet, captured at
  // settlement. clv = odds/closingOdds - 1; consistently positive CLV = real predictive skill.
  closingOdds     Float?
  clv             Float?
  settledAt       DateTime?
  createdAt       DateTime  @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([fixtureId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
